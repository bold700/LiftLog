# Firebase – kopieer naar .env en vul je eigen waarden in.
# .env wordt NIET naar Git geüpload (staat in .gitignore).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optioneel (voor Analytics):
# VITE_FIREBASE_MEASUREMENT_ID=

# OpenAI (server-side, voor AI workout generator op /api/generate-workout)
OPENAI_API_KEY=
# Optioneel: ander model kiezen
# OPENAI_MODEL=gpt-4.1-mini
