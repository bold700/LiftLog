# Firebase – kopieer naar .env en vul je eigen waarden in.
# .env wordt NIET naar Git geüpload (staat in .gitignore).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optioneel (voor Analytics):
# VITE_FIREBASE_MEASUREMENT_ID=

# OpenAI (server-side, voor AI workout generator op /api/generate-workout)
OPENAI_API_KEY=
# Optioneel: ander model kiezen
# OPENAI_MODEL=gpt-4.1-mini

# ExerciseDB / RapidAPI — server-side demo (media + evt. video) bij schema-training
# Aanrader (11k+): https://rapidapi.com/ascendapi/api/edb-with-videos-and-images-by-ascendapi
# Legacy (1.3k/2k): https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
# EXERCISEDB_RAPIDAPI_KEY=
# Optioneel (default = nieuwe AscendAPI V2 host):
# EXERCISEDB_RAPIDAPI_HOST=edb-with-videos-and-images-by-ascendapi.p.rapidapi.com
# Optioneel: forceer endpointstijl ('v2' of 'v1'). Standaard auto op basis van host.
# EXERCISEDB_API_KIND=v2

# Optioneel: Capacitor / native build — absolute URL naar je Vercel-backend (zonder slash aan het eind)
# VITE_APP_API_ORIGIN=https://jouw-app.vercel.app

# Optioneel: andere poort voor local-api-server (default 3001) — moet gelijk zijn aan LOCAL_API_PORT
# VITE_DEV_API_PORT=3001
