rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Profielen: eigen profiel + trainers mogen sporters beheren + beheerders mogen alles (o.a. trainer-aanvragen)
    match /profiles/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
            || resource.data.trainerId == request.auth.uid
            || get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'trainer'
            || get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null
        && (request.auth.uid == userId
            || get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'trainer'
            || get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin');
    }
    // Workouts: alleen eigen (trainer of toegewezen sporter)
    match /workouts/{workoutId} {
      allow read: if request.auth != null
        && (resource.data.trainerId == request.auth.uid
            || resource.data.clientId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.trainerId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.trainerId == request.auth.uid;
    }
    // Openbare ranglijst: alleen geaggregeerde totalen; iedere ingelogde gebruiker mag lezen.
    // Schrijven alleen eigen document (client zet visibility + label; geen ruwe logs).
    match /leaderboardPublic/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    function isTrainerOrAdmin() {
      return request.auth != null
        && (get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'trainer'
            || get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin');
    }

    // Per-persoon oefening-logs (groepsles + individueel). Eigen logs of via je trainer/admin.
    match /logs/{logId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || resource.data.trainerId == request.auth.uid
            || isTrainerOrAdmin());
      allow create: if request.auth != null
        && (request.resource.data.userId == request.auth.uid
            || request.resource.data.loggedBy == request.auth.uid
            || isTrainerOrAdmin());
      allow update, delete: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || resource.data.loggedBy == request.auth.uid
            || isTrainerOrAdmin());
    }

    // Groepsles-sessies. Trainer beheert; deelnemers mogen hun sessie lezen.
    match /sessions/{sessionId} {
      allow read: if request.auth != null
        && (resource.data.trainerId == request.auth.uid
            || request.auth.uid in resource.data.participantIds
            || isTrainerOrAdmin());
      allow create: if request.auth != null
        && request.resource.data.trainerId == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.data.trainerId == request.auth.uid
            || isTrainerOrAdmin());
    }
  }
}
