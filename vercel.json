{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/generate-workout.mjs": {
      "includeFiles": "src/data/*.json",
      "maxDuration": 60
    },
    "api/exercise-demo.mjs": {
      "includeFiles": "src/data/*.json"
    },
    "api/exercise-search.mjs": {
      "includeFiles": "src/data/*.json"
    },
    "api/food-photo.mjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

