{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/generate-workout.mjs": {
      "includeFiles": "src/data/mega_exercise_db.json",
      "maxDuration": 60
    },
    "api/exercise-demo.mjs": {
      "includeFiles": "src/data/mega_exercise_db.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

